# ──────────────────────────────────────────────────────────
# SvelteKit — Runtime environment variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────

# URL of the Directus CMS instance (used server-side and at build time)
PUBLIC_DIRECTUS_URL=https://cms.progetta.ch

# The canonical origin of this SvelteKit app.
# Required by adapter-node to correctly build absolute URLs / CSRF protection.
ORIGIN=https://www.matteosnozzi.ch
